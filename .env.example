# API Keys — DO NOT COMMIT THIS FILE
# Copy to .env and fill in your real keys. .env is gitignored.

# Google Gemini (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenRouter (get from https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=

# Optional: pick a default model on OpenRouter
# Examples: anthropic/claude-sonnet-4.5, openai/gpt-4o, google/gemini-flash-latest
OPENROUTER_MODEL=google/gemini-flash-latest